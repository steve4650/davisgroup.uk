[
  {
    "tags": "static_Files",
    "block": [
      {
        "name": "Create /var/www/html/",
        "ansible.builtin.file": {
          "path": "/var/www/html",
          "state": "directory",
          "mode": "0755",
          "owner": "root",
          "group": "root",
          "seuser": "system_u",
          "serole": "object_r",
          "setype": "httpd_sys_content_t",
          "selevel": "s0"
        },
        "become": "yes"
      },
      {
        "name": "Create /var/www/html-predeploy/",
        "ansible.builtin.file": {
          "path": "/var/www/html-predeploy",
          "state": "directory",
          "mode": "0755",
          "owner": "steve",
          "group": "steve",
          "seuser": "system_u",
          "serole": "object_r",
          "setype": "httpd_sys_content_t",
          "selevel": "s0"
        },
        "become": "yes"
      },
      {
        "name": "Copy deploy.sh to /usr/local/bin/",
        "ansible.builtin.copy": {
          "src": "deploy.sh",
          "dest": "/usr/local/bin/deploy.sh",
          "mode": "0755",
          "owner": "root",
          "group": "root",
          "seuser": "system_u",
          "serole": "object_r",
          "setype": "bin_t",
          "selevel": "s0"
        },
        "become": "yes"
      },
      {
        "name": "Create systemd service file for deploy",
        "ansible.builtin.copy": {
          "dest": "/etc/systemd/system/deploy.service",
          "content": "[Unit]\nDescription=Deploy script\n\n[Service]\nType=oneshot\nExecStart=/usr/local/bin/deploy.sh\n",
          "mode": "0644",
          "owner": "root",
          "group": "root",
          "seuser": "system_u",
          "serole": "object_r",
          "setype": "systemd_unit_file_t",
          "selevel": "s0"
        },
        "become": "yes",
        "register": "deploy_service_file"
      },
      {
        "name": "Create systemd timer file for deploy",
        "ansible.builtin.copy": {
          "dest": "/etc/systemd/system/deploy.timer",
          "content": "[Unit]\nDescription=Run deploy script every 10 minutes\nRequires=deploy.service\n\n[Timer]\nOnBootSec=10min\nOnUnitActiveSec=10min\n\n[Install]\nWantedBy=timers.target\n",
          "mode": "0644",
          "owner": "root",
          "group": "root"
        },
        "become": "yes",
        "register": "deploy_timer_file"
      },
      {
        "name": "Enable and start deploy timer",
        "ansible.builtin.systemd": {
          "name": "deploy.timer",
          "enabled": true,
          "state": "started",
          "daemon_reload": true
        },
        "become": "yes",
        "when": "deploy_service_file.changed or deploy_timer_file.changed"
      }
    ]
  }
]
